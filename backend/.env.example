# Copy this file to .env.local for local development.
# Never commit .env.local, .env.dev, or .env.prod — they are gitignored.
# In dev/prod, these variables are injected by the deployment platform.

DATABASE_URL=postgres://user:password@localhost:5432/sports_manager?sslmode=disable
JWT_SECRET=replace-with-a-long-random-secret

# SMTP settings for invite emails.
# Leave SMTP_HOST empty to run in no-op mode (emails are logged, not sent).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# Base URL used to build invite accept links in emails.
APP_URL=http://localhost:5173
